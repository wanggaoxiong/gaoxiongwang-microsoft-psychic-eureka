# Copy to .env.local and fill in
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wa_ai?schema=public"
REDIS_URL="redis://localhost:6379"

# WhatsApp Cloud API
WA_PHONE_NUMBER_ID=""
WA_ACCESS_TOKEN=""
WA_WEBHOOK_VERIFY_TOKEN="dev-verify-token"

# WhatsApp Personal (QR login)
# 在受限网络环境下，给 whatsapp-web.js/Chromium 显式指定代理。
# ClashX Pro mixed 口常见形如 http://127.0.0.1:5678
WA_PROXY_SERVER=""
# 可选：直连白名单，语法同 Chromium --proxy-bypass-list
WA_PROXY_BYPASS=""

# Supplier credentials (encrypted at rest in DB normally; .env only for dev)
GXHYAPP_USERNAME=""
GXHYAPP_PASSWORD=""

# AI — Azure AI Foundry / Azure OpenAI（用法对齐 receipt-tracker：v1 Responses API）
# Endpoint 形如 https://YOUR-RESOURCE.openai.azure.com 或 https://YOUR-RESOURCE.cognitiveservices.azure.com
# 末尾不要带 /openai 或 /openai/v1/responses，代码里会自动 normalize
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
# 模型 / 部署名（model 字段直接使用 deployment name），默认 gpt-5.4
AZURE_OPENAI_DEPLOYMENT="gpt-5.4"

# Object storage (S3-compatible, e.g. MinIO/R2)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="wa-ai"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"

# Master encryption key for stored credentials (32-byte base64)
SECRET_BOX_KEY=""
